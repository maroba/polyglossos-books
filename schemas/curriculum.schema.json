{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Master-Curriculum eines Buches",
  "type": "object",
  "required": ["book", "l1", "l2", "target_cefr", "chapters"],
  "additionalProperties": false,
  "properties": {
    "book": { "type": "string" },
    "l1": { "type": "string", "description": "Metasprache (ISO 639-1)" },
    "l2": { "type": "string", "description": "Zielsprache (ISO 639-1)" },
    "target_cefr": { "enum": ["A1", "A2", "B1", "B2", "C1", "C2"] },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "chapters"],
        "additionalProperties": false,
        "properties": {
          "level": { "enum": ["A0", "A1", "A2", "B1", "B2", "C1", "C2"] },
          "chapters": {
            "type": "array",
            "description": "[erstes, letztes] Kapitel der Einheit",
            "items": { "type": "integer", "minimum": 1 },
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "slug", "cefr", "title_de", "can_do", "grammar_new", "vocab_target"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "cefr": { "enum": ["A0", "A1", "A2", "B1", "B2", "C1", "C2"] },
          "title_de": { "type": "string" },
          "can_do": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "grammar_new": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label_de"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "label_de": { "type": "string" }
              }
            }
          },
          "grammar_recycle": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Grammatik-IDs aus früheren Kapiteln, die hier wiederholt werden"
          },
          "vocab_target": { "type": "integer", "minimum": 0 },
          "vocab_themes": { "type": "array", "items": { "type": "string" } },
          "vocab_recycle_min": { "type": "integer", "minimum": 0 },
          "cultural_topic": { "type": ["string", "null"] },
          "depends_on": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
